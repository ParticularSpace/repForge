generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  name                 String?
  displayName          String?  @map("display_name")
  age                  Int?
  weightLbs            Float?   @map("weight_lbs")
  heightIn             Float?   @map("height_in")
  gender               String?
  fitnessGoal          String?  @map("fitness_goal")
  experienceNotes      String?  @map("experience_notes")
  preferredRestSeconds Int?     @map("preferred_rest_seconds") @default(60)
  equipmentPreferences Json?     @map("equipment_preferences") @default("[]")
  subscriptionStatus   String    @default("free") @map("subscription_status")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  proGrantedByAdmin    Boolean   @default(false) @map("pro_granted_by_admin")
  subscriptionEndsAt   DateTime? @map("subscription_ends_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt      @map("updated_at")
  @@map("users")
}

model Workout {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  name        String
  type        String
  difficulty  String
  startedAt   DateTime   @default(now()) @map("started_at")
  completedAt DateTime?  @map("completed_at")
  durationMin Int?       @map("duration_min")
  source      String     @default("manual")
  exercises   Exercise[]
  @@map("workouts")
}

model Exercise {
  id           String   @id @default(uuid())
  workoutId    String   @map("workout_id")
  workout      Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name         String
  order        Int
  sets         Int
  reps         Int
  weightLbs    Float?   @map("weight_lbs")
  notes        String?
  description  String?
  muscleGroups Json?    @map("muscle_groups") @default("[]")
  modification String?
  coachingCue  String?  @map("coaching_cue")
  setLogs      SetLog[]
  @@map("exercises")
}

model SetLog {
  id            String   @id @default(uuid())
  exerciseId    String   @map("exercise_id")
  exercise      Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  setNumber     Int      @map("set_number")
  completedAt   DateTime @default(now()) @map("completed_at")
  actualReps    Int?     @map("actual_reps")
  actualWeight  Float?   @map("actual_weight")
  @@map("set_logs")
}

model ExerciseLibrary {
  id           String   @id @default(uuid())
  name         String   @unique
  muscleGroups Json     @map("muscle_groups") @default("[]")
  description  String?
  equipment    String?
  isCustom     Boolean  @default(false) @map("is_custom")
  createdBy    String?  @map("created_by")
  @@map("exercise_library")
}

model WorkoutTemplate {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  name       String
  type       String?
  source     String             @default("manual")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  lastUsedAt DateTime?          @map("last_used_at")
  useCount   Int                @default(0) @map("use_count")
  exercises  TemplateExercise[]
  @@unique([userId, name, source])
  @@map("workout_templates")
}

model TemplateExercise {
  id           String          @id @default(uuid())
  templateId   String          @map("template_id")
  template     WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name         String
  order        Int
  sets         Int
  reps         Int
  weightLbs    Float?          @map("weight_lbs")
  restSeconds  Int?            @map("rest_seconds")
  muscleGroups Json?           @map("muscle_groups") @default("[]")
  @@map("template_exercises")
}
